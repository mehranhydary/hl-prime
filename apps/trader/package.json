{
  "name": "hl-prime-trader",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "npm --prefix ../.. run build && tsx watch server/src/index.ts",
    "dev:web": "vite",
    "build": "npm run build:server && npm run build:web",
    "build:server": "npm --prefix ../.. run build && tsc -p server/tsconfig.json",
    "build:web": "vite build",
    "start": "npm run build:server && node server/dist/server/src/index.js",
    "typecheck": "tsc --noEmit -p server/tsconfig.json && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nktkas/hyperliquid": "^0.31.0",
    "@types/ws": "^8.18.1",
    "cors": "^2.8.5",
    "express": "^5.0.1",
    "hyperliquid-prime": "file:../..",
    "lightweight-charts": "^5.1.0",
    "qrcode": "^1.5.4",
    "uuid": "^11.0.0",
    "viem": "^2.21.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.60.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
