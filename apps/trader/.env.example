# Required for Privy-backed web auth and API token verification.
# Also required at build time for the web app.
VITE_TRADER_PRIVY_APP_ID=your-privy-app-id
TRADER_PRIVY_APP_ID=your-privy-app-id
TRADER_PRIVY_JWT_VERIFICATION_KEY=your-privy-jwt-verification-key

# Required when local signer storage is enabled:
# - TRADER_SIGNER_BACKEND=local
# - OR TRADER_SIGNER_LOCAL_FALLBACK=true
TRADER_STORE_PASSPHRASE=your-secret-passphrase-here
# Required: app unlock password for non-landing routes and protected APIs (min 16 chars)
TRADER_APP_PASSWORD=replace-with-strong-password-min-16

# Optional: server config
TRADER_PORT=4400
# Railway/container deploys should bind 0.0.0.0.
TRADER_HOST=0.0.0.0
TRADER_DATA_DIR=.data
TRADER_DEFAULT_NETWORK=mainnet
# Optional: app unlock token lifetime in days (1-30)
TRADER_APP_PASSWORD_TTL_DAYS=7

# Optional: stable tokens for unified USD balance (comma-separated)
TRADER_STABLE_TOKENS=USDC,USDH,USDE,USDT0

# Optional: builder fee config
TRADER_BUILDER_ADDRESS=0x34411c9d3c312e6ECb32C079AA0F34B572Dddc37
TRADER_BUILDER_FEE_BPS=1

# Optional: agent wallet expiry in days
TRADER_AGENT_EXPIRY_DAYS=30

# Optional: auth and runtime security
TRADER_AUTH_ENABLED=true
TRADER_DEV_INSECURE=false
# Optional: diagnostic routes like /api/account/debug-prices (keep false in prod)
TRADER_ENABLE_DEBUG_ROUTES=false
# Required in production. Comma-separate multiple trusted origins.
TRADER_ALLOWED_ORIGINS=https://app.example.com,https://<service>.up.railway.app

# Optional: signer backend
# local = encrypted local signer storage
# privy = Privy-managed agent signing
TRADER_SIGNER_BACKEND=local
# Emergency-only fallback when primary signer backend is privy
TRADER_SIGNER_LOCAL_FALLBACK=false

# Optional: runtime state backend
TRADER_RUNTIME_STATE_BACKEND=sqlite
# Defaults to ${TRADER_DATA_DIR}/runtime-state.db when unset
# TRADER_RUNTIME_STATE_SQLITE_PATH=/data/runtime-state.db

# Required only when TRADER_SIGNER_BACKEND=privy
# TRADER_PRIVY_APP_SECRET=
# TRADER_PRIVY_AUTHORIZATION_KEY=
